      </encoder>
    </appender>
    
    <appender name="SystemErr" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>logs/system.err</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
        <fileNamePattern>logs/older/system-%i.err.zip</fileNamePattern>
        <minIndex>1</minIndex>
        <maxIndex>2</maxIndex>
      </rollingPolicy>
      <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
        <maxFileSize>5MB</maxFileSize>
      </triggeringPolicy>
      <encoder>
        <pattern>${pattern}</pattern>
      </encoder>
    </appender>
    
    <logger name="com.hazeluff.discord.bot.gdc.nhl.NHLGameDayWatchChannel" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLGDW"/>
    </logger>
    
    <logger name="com.hazeluff.discord.bot.gdc.nhl.NHLGdcGuildManager" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLGDCManager"/>
    </logger>
    
    <logger name="com.hazeluff.discord.bot.gdc.nhl" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLGDT"/>
    </logger>
    
    <logger name="com.hazeluff.discord.bot.gdc.ahl.AHLWatchChannel" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="AHLGDW"/>
    </logger>
    
    <logger name="com.hazeluff.discord.bot.gdc.ahl" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="AHLGDT"/>
    </logger>
    
    <logger name="com.hazeluff.discord.nhl" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLGameScheduler"/>
    </logger>
    
    <logger name="com.hazeluff.nhl.game" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLGameScheduler"/>
    </logger>
    
    <logger name="com.hazeluff.discord.ahl" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="AHLGameScheduler"/>
    </logger>
    
    <logger name="com.hazeluff.ahl.game" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="AHLGameScheduler"/>
    </logger>
    
    <logger name="com.hazeluff.nhl.NHLGateway" level="info" additivity="false">
      <appender-ref ref="Gateway"/>
    </logger>
    
    <logger name="com.hazeluff.ahl.AHLGateway" level="info" additivity="false">
      <appender-ref ref="Gateway"/>
    </logger>
    
    <logger name="com.hazeluff.discord.bot.ExceptionHandler" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="SystemErr"/>
    </logger>
    
    <logger name="com.hazeluff.discord" level="info" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLBot"/>
    </logger>
    
    <logger name="com.hazeluff.discord" level="warn" additivity="false">
      <appender-ref ref="Console"/>
      <appender-ref ref="NHLBotError"/>
    </logger>
    
    <root level="info">
      <appender-ref ref="Console"/>
      <appender-ref ref="System"/>
    </root>
</configuration>